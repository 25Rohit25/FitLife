pipeline {
    agent any
    
    stages {
        stage('Build Backend') {
            steps {
                dir('server-java') {
                    bat 'mvn clean package -DskipTests'
                }
            }
        }
        
        stage('Build Frontend') {
            steps {
                dir('client') {
                    bat 'npm ci'
                    bat 'npm run build'
                }
            }
        }
        
        stage('Docker Build') {
            steps {
                bat 'docker-compose build'
            }
        }
    }
}
